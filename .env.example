## Example .env values (SAFE to commit — use dummy/example values only)
# Copy this file to .env and fill in your real credentials
# The .env file is in .gitignore to prevent exposing secrets

# Contact Information
PORTFOLIO_EMAIL=your-email@example.com
PORTFOLIO_PHONE=+1 000-000-0000
PORTFOLIO_LINKEDIN=your-linkedin-profile

# Web3Forms API Key (get yours from https://web3forms.com)
WEB3FORMS_KEY=your_web3forms_access_key_here
